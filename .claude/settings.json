{
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Bash(git commit *)",
      "Bash(git add *)",
      "Bash(git push *)",
      "Bash(git rev-parse *)",
      "Bash(sed -i *)"
    ]
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-test.sh",
            "timeout": 120,
            "statusMessage": "Running auto-tests..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/commit-gate.sh",
            "if": "Bash(git commit *)",
            "timeout": 120,
            "statusMessage": "Pre-commit test gate..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-context.sh",
            "timeout": 10,
            "statusMessage": "Loading project context..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-compact.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-cleanup.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.kube",
        "~/.gnupg",
        "~/.config/gcloud",
        "//etc/shadow",
        "//etc/passwd"
      ],
      "denyWrite": [
        "~/.ssh",
        "~/.aws",
        "~/.kube",
        "~/.gnupg",
        "//bin",
        "//usr/bin",
        "//sbin"
      ]
    },
    "network": {
      "allowedHosts": [
        "github.com",
        "*.github.com",
        "codeload.github.com",
        "objects.githubusercontent.com"
      ]
    }
  }
}
